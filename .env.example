# ─────────────────────────────────────────────────────────────
# Email Automation System — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Django
SECRET_KEY=your-super-secret-django-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (PostgreSQL)
DB_NAME=email_automation
DB_USER=postgres
DB_PASSWORD=securepassword
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_HOST=127.0.0.1
REDIS_URL=redis://127.0.0.1:6379/0

# Email — SMTP (Gmail)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password       # Gmail App Password (not your Gmail password)
DEFAULT_FROM_EMAIL=TechAcademy <your-gmail@gmail.com>

# Email — SendGrid (alternative to Gmail SMTP)
# EMAIL_BACKEND=sendgrid_backend.EmailBackend
SENDGRID_API_KEY=your-sendgrid-api-key

# AI — Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_WS_URL=ws://localhost:8000/ws
